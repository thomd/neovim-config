{
  "main guard": {
    "prefix": "main",
    "body": ["if __name__ == \"__main__\":", "\t${1:main()}"],
    "description": "Python entry-point guard"
  },
  "function": {
    "prefix": "def",
    "body": ["def ${1:name}(${2:args}) -> ${3:None}:", "\t${4:pass}"],
    "description": "Function definition with return type"
  }
}
